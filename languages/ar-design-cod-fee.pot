msgstr ""

msgid "Prah objednávky pre dobierku zdarma"
msgstr ""

msgid "Pre aktuálne zvoleného dopravcu (%1$s) je extra poplatok za dobierku %2$s."
msgstr ""

msgid "Pre aktuálne zvoleného dopravcu (%s) sa teraz extra poplatok za dobierku neuplatní."
msgstr ""

msgid "Režim výpočtu extra dobierky"
msgstr ""

msgid "Samostatný modul pre nastaviteľnú extra dobierku podľa dopravcu vo WooCommerce."
msgstr ""

msgid "Text zobrazený zákazníkovi pri pokladni. Extra dobierkový poplatok riadi AR Design COD Fee modul v WooCommerce > Shipping > COD podľa dopravcu."
msgstr ""

msgid "Táto sekcia je nový source of truth pre extra dobierkový poplatok podľa zvolenej dopravy. Pôvodná WooCommerce COD gateway zostáva platobnou metódou, ale cenu extra dobierky riadi výhradne tento modul."
msgstr ""

msgid "V režimu „pevná částka“ se používají pole níže s částkou pro každého dopravce. V režimu „podle ceny objednávky“ se používají cenová pravidla."
msgstr ""

msgid "Výchozí cenová pravidla pro ostatní dopravce"
msgstr ""

msgid "Výchozí dobierka pre ostatných dopravcov"
msgstr ""

msgid "Ak je hodnota košíka vyššia ako tento prah, extra dobierka z tejto sekcie sa nebude účtovať. Nastavte 0 alebo nechajte prázdne, ak nechcete globálny limit."
msgstr ""

msgid "Extra dobierkový poplatok pre DPD metódy (`wc_dpd_*`, prípadne `slovakparcelservice_*`). Můžete zadat pevnou částku `1.5` nebo procento z objednávky `2.5%`."
msgstr ""

msgid "Extra dobierkový poplatok pre GLS metódy. Můžete zadat pevnou částku `1.5` nebo procento z objednávky `2.5%`."
msgstr ""

msgid "Extra dobierkový poplatok pre Packetu. Můžete zadat pevnou částku `1.5` nebo procento z objednávky `2.5%`. Poznámka: Packeta môže mať zároveň vlastný COD surcharge v carrier nastaveniach."
msgstr ""

msgid "Extra dobierkový poplatok pre `local_pickup`. Můžete zadat pevnou částku `1.5` nebo procento z objednávky `2.5%`."
msgstr ""
